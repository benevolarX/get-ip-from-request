{
  "name": "get-ip-from-request",
  "version": "1.1.0",
  "description": "get ip client from request and validate ip (v4/v6)",
  "source": "lib/index.js",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.mjs",
  "exports": {
    ".": {
      "require":  "./dist/index.js",
      "node": "./dist/index.esm.mjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "commonjs",
  "types": "./lib/index.d.ts",
  "engines": {
    "node": ">=14.16.0"
  },
  "scripts": {
    "bench": "node benchmark/index.js",
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "esbuild lib/index.js --bundle --resolve-extensions=.mjs,.js --platform=node --target=es2020 --format=cjs --outfile=/dist/index.js",
    "build:esm": "esbuild lib/index.mjs --bundle --resolve-extensions=.mjs,.js --platform=node --target=es2020 --format=esm --outfile=/dist/index.esm.mjs",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "node tests/index.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benevolarX/get-ip-from-request.git"
  },
  "keywords": [
    "ip",
    "request",
    "ipv4",
    "ipv6",
    "regex",
    "client",
    "address",
    "headers",
    "validate",
    "es2020",
    "get",
    "from"
  ],
  "author": "benevolarX",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/benevolarX/get-ip-from-request/issues"
  },
  "homepage": "https://github.com/benevolarX/get-ip-from-request#readme",
  "devDependencies": {
    "benchmark": "^2.1.4",
    "esbuild": "^0.8.50",
    "is_js": "^0.9.0",
    "microtime": "^3.0.0",
    "rimraf": "^3.0.2",
    "tape": "^5.2.0"
  }
}
